# Copy to .env and fill in real values. Never commit .env.

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Database
POSTGRES_PASSWORD=choose_a_strong_password

# Auth — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Redis (resolved inside Docker network — usually no change needed)
REDIS_URL=redis://redis:6379/0

# Database URL (resolved inside Docker network — usually no change needed)
DATABASE_URL=postgresql://meddoc:your_postgres_password@postgres:5432/meddocintel
